---
import HomeLayout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ProductsGrid from "../components/ProductsGrid.astro";
import Algorithm from "../components/Algorithm.astro";
---

<HomeLayout>
  <div id="container">
	<Header />
    <main class="md:px-12">
      <section id="hero">
        <h1 class="text-center text-balance">Curadoria inteligente para o seu cabelo.</h1>
        <div class="flex gap-4">
          <a
            class="rounded-full bg-(--clay) px-3 py-2 text-(--bg) transition-colors hover:bg-(--clay-hover)"
            href="#algoritmo">Algoritmo</a
          >
          <a
            class="rounded-full bg-(--red) px-3 py-2 text-(--bg) transition-colors hover:bg-(--red-hover)"
            href="#acervo">Acervo</a
          >
        </div>
      </section>
      <section
        id="algoritmo"
        class="relative w-full h-[66vh] scroll-mt-24 rounded-[120px] lg:rounded-full overflow-hidden"
      >
		<Algorithm />
      </section>
	  <section id="acervo" class="my-34 scroll-mt-24">
		  <h2 class="pb-13">Acervo</h2>
		  <ProductsGrid />
	  </section>
	  
    </main>
  </div>
</HomeLayout>

<style>
  #hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    height: 66vh;
  }

  section {
	display: flex;
	flex-direction: column;
	align-items: center;
  }
</style>
