---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  product: CollectionEntry<"products">;
}

const { product } = Astro.props;
---

<a
  class="product-card"
  data-product-card
  data-compatibility={product.data.compatibility}
  href={product.data.link}
  target="_blank"
  rel="noreferrer"
>
  <Image
    src={product.data.image}
    alt={product.data.imageAlt}
    class="product-image"
  />

  <h1 class="pt-3.25 text-center">{product.data.title}</h1>
  <h1 class="text-center text-(--muted)">{product.data.caption}</h1>
  <div class="buy-row mt-5.25">
    <button class="buy-button bg-(--card) hover:border-(--stroke) text-(--text)">
      Menor preço — {product.data.price}
    </button>
    <button
      class="compatibility-score"
      data-compatibility-score
      title="Compatibilidade com seu perfil capilar"
      aria-label="Compatibilidade com seu perfil capilar"
      hidden
    ></button>
  </div>
</a>

<style lang="scss">
  .product-card {
    display: flex;
    align-items: center;
    flex-direction: column;
    gap: 0.5rem;
    color: inherit;
    text-decoration: none;
  }

  .buy-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .buy-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .compatibility-score {
    border-radius: 999px;
    background: var(--score-background, var(--card));
    color: var(--score-text, var(--text));
    font-weight: 500;
  }

  .product-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: contain;
    /* border-radius: 10rem; */
    scale: 0.75;
  }
</style>
