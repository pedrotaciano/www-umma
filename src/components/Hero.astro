---
import { Image } from "astro:assets";
import hero from "../assets/hero.png";
---

<div id="container">
  <main>
    <section id="hero">
      <h1>Curadoria inteligente para o seu cabelo.</h1>
      <div class="gap-4">
        <button class="bg-(--clay) hover:bg-(--clay-hover) text-(--bg)">Algoritmo</button>
        <button class="bg-(--red) hover:bg-(--red-hover) text-(--bg)">Acervo</button>
      </div>
    </section>
    <section class="relative w-full rounded-full overflow-hidden">
      <Image
        class="w-full h-full object-cover"
        src={hero}
        alt="Mulher lavando o cabelo"
      />
	  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-4">
		  <h1 class="text-(--bg)">Calibrar algoritmo</h1>
		  <button class="bg-(--clay) hover:bg-(--clay-hover) text-(--bg)">Iniciar (1min)</button>
	  </div>
    </section>
  </main>
</div>

<style>
  #container {
    width: 100%;
    height: 133dvh;
  }

  main {
    height: 100%;
    padding-inline: 12rem;
  }

  #hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    height: 66dvh;
  }
</style>
